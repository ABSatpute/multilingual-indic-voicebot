# Copy this file to .env and fill in your values
# NEVER commit .env to git

# AWS region where Bedrock and ECS are deployed
AWS_DEFAULT_REGION=ap-south-1

# Bedrock Knowledge Base ID (from AWS Console → Bedrock → Knowledge Bases)
KNOWLEDGE_BASE_ID=

# Cognito User Pool ID (from CDK deploy output)
USER_POOL_ID=

# Cognito App Client ID (from CDK deploy output)
APP_CLIENT_ID=

# Bedrock LLM model ID for regional languages
# Options: apac.amazon.nova-lite-v1:0 | apac.amazon.nova-pro-v1:0
LLM_MODEL=apac.amazon.nova-lite-v1:0

# AWS Secrets Manager secret NAME (not the value) for Smallest.ai API key
# Create with: aws secretsmanager create-secret --name "smallest_key" --secret-string "sk_..."
SMALLEST_API_KEY=smallest_key
